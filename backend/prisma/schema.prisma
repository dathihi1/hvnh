generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USERS
// ==========================================
model User {
  userId                Int                    @id @default(autoincrement())
  userName              String
  studentId             String?
  university            String
  phoneNumber           String?                @unique
  email                 String                 @unique
  password              String
  status                String                 @default("active")
  avatarUrl             String?
  isDeleted             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())
  deletedAt             DateTime?
  createdBy             Int?
  updatedBy             Int?
  deletedBy             Int?

  clubApplications      ClubApplication[]
  notifications         Notification[]
  organizationDocuments OrganizationDocument[]
  organizationMembers   OrganizationMember[]
  registrations         Registration[]
  systemLogs            SystemLog[]
  teamMembers           TeamMember[]
  userRoles             UserRole[]

  @@unique([studentId, university])
  @@map("users")
}

// ==========================================
// ORGANIZATIONS
// ==========================================
model Organization {
  organizationId        Int                    @id @default(autoincrement())
  organizationName      String
  organizationType      String
  logoUrl               String?
  coverImageUrl         String?
  description           String?
  isDeleted             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())
  deletedAt             DateTime?
  createdBy             Int?
  updatedBy             Int?
  deletedBy             Int?

  activities            Activity[]
  organizationDocuments OrganizationDocument[]
  organizationMembers   OrganizationMember[]

  @@map("organizations")
}

model OrganizationMember {
  userId         Int
  organizationId Int
  role           String?
  joinDate       DateTime?    @db.Date
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  organization   Organization @relation(fields: [organizationId], references: [organizationId])
  user           User         @relation(fields: [userId], references: [userId])

  @@id([userId, organizationId])
  @@map("organization_members")
}

model OrganizationDocument {
  documentId     Int          @id @default(autoincrement())
  documentName   String
  fileUrl        String
  category       String?
  organizationId Int
  userId         Int
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  organization   Organization @relation(fields: [organizationId], references: [organizationId])
  user           User         @relation(fields: [userId], references: [userId])

  @@map("organization_documents")
}

// ==========================================
// ACTIVITIES
// ==========================================
model ActivityCategory {
  categoryId   Int        @id @default(autoincrement())
  categoryName String     @unique
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now())
  deletedAt    DateTime?
  createdBy    Int?
  updatedBy    Int?
  deletedBy    Int?

  activities   Activity[]

  @@map("activity_categories")
}

model Activity {
  activityId           Int               @id @default(autoincrement())
  activityName         String
  description          String?
  coverImage           String?
  location             String?
  activityType         String
  teamMode             String            @default("individual")
  startTime            DateTime?
  endTime              DateTime?
  registrationDeadline DateTime?
  minParticipants      Int?
  maxParticipants      Int?
  activityStatus       String            @default("draft")
  prize                String?
  organizationId       Int
  categoryId           Int
  isDeleted            Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @default(now())
  deletedAt            DateTime?
  createdBy            Int?
  updatedBy            Int?
  deletedBy            Int?

  organization         Organization      @relation(fields: [organizationId], references: [organizationId])
  category             ActivityCategory  @relation(fields: [categoryId], references: [categoryId])
  activityCheckins     ActivityCheckin[]
  activityTeamRule     ActivityTeamRule?
  clubApplications     ClubApplication[]
  registrations        Registration[]

  @@map("activities")
}

model ActivityCheckin {
  checkinId    Int       @id @default(autoincrement())
  activityId   Int
  checkInTime  DateTime?
  checkOutTime DateTime?

  activity             Activity              @relation(fields: [activityId], references: [activityId], onDelete: Cascade)
  registrationCheckins RegistrationCheckin[]

  @@map("activity_checkins")
}

model ActivityTeamRule {
  ruleId         Int      @id @default(autoincrement())
  activityId     Int      @unique
  minTeamMembers Int?
  maxTeamMembers Int?

  activity       Activity @relation(fields: [activityId], references: [activityId], onDelete: Cascade)

  @@map("activity_team_rules")
}

// ==========================================
// REGISTRATIONS
// ==========================================
model Registration {
  registrationId   Int       @id @default(autoincrement())
  teamName         String?
  isLookingForTeam Boolean?
  status           String    @default("pending")
  registrationTime DateTime  @default(now())
  registrationType String    @default("individual")
  userId           Int
  activityId       Int
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())
  deletedAt        DateTime?
  createdBy        Int?
  updatedBy        Int?
  deletedBy        Int?

  activity             Activity              @relation(fields: [activityId], references: [activityId])
  user                 User                  @relation(fields: [userId], references: [userId])
  registrationCheckins RegistrationCheckin[]
  review               Review?
  teamMembers          TeamMember[]

  @@unique([userId, activityId])
  @@map("registrations")
}

model RegistrationCheckin {
  checkinId         Int       @id @default(autoincrement())
  registrationId    Int
  activityCheckinId Int?
  checkInTime       DateTime?
  checkOutTime      DateTime?

  registration    Registration     @relation(fields: [registrationId], references: [registrationId], onDelete: Cascade)
  activityCheckin ActivityCheckin? @relation(fields: [activityCheckinId], references: [checkinId])

  @@unique([registrationId, activityCheckinId])
  @@map("registration_checkins")
}

model TeamMember {
  registrationId Int
  userId         Int
  role           String?
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  registration   Registration @relation(fields: [registrationId], references: [registrationId])
  user           User         @relation(fields: [userId], references: [userId])

  @@id([registrationId, userId])
  @@map("team_members")
}

model Review {
  reviewId       Int          @id @default(autoincrement())
  rating         Int
  comment        String?
  reviewTime     DateTime     @default(now())
  registrationId Int          @unique
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  registration   Registration @relation(fields: [registrationId], references: [registrationId])

  @@map("reviews")
}

model ClubApplication {
  applicationId Int       @id @default(autoincrement())
  submittedAt   DateTime  @default(now())
  interviewTime DateTime?
  result        String    @default("pending")
  note          String?
  activityId    Int
  userId        Int
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  deletedAt     DateTime?
  createdBy     Int?
  updatedBy     Int?
  deletedBy     Int?

  activity      Activity  @relation(fields: [activityId], references: [activityId])
  user          User      @relation(fields: [userId], references: [userId])

  @@unique([activityId, userId])
  @@map("club_applications")
}

// ==========================================
// NOTIFICATIONS
// ==========================================
model Notification {
  notificationId   Int       @id @default(autoincrement())
  title            String
  content          String?
  notificationTime DateTime  @default(now())
  status           String    @default("unread")
  notificationType String?
  userId           Int
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())
  deletedAt        DateTime?
  createdBy        Int?
  updatedBy        Int?
  deletedBy        Int?

  user             User      @relation(fields: [userId], references: [userId])

  @@map("notifications")
}

// ==========================================
// ROLES
// ==========================================
model Role {
  roleId      Int        @id @default(autoincrement())
  code        String     @unique
  roleName    String     @unique
  description String?
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now())
  deletedAt   DateTime?
  createdBy   Int?
  updatedBy   Int?
  deletedBy   Int?

  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  userId    Int
  roleId    Int
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  role      Role      @relation(fields: [roleId], references: [roleId])
  user      User      @relation(fields: [userId], references: [userId])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ==========================================
// SYSTEM
// ==========================================
model SystemLog {
  logId         Int       @id @default(autoincrement())
  action        String?
  executionTime DateTime  @default(now())
  oldData       String?
  newData       String?
  userId        Int
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  deletedAt     DateTime?
  createdBy     Int?
  updatedBy     Int?
  deletedBy     Int?

  user          User      @relation(fields: [userId], references: [userId])

  @@map("system_logs")
}
