generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USERS
// ==========================================
model User {
  userId                Int                    @id @default(autoincrement())
  userName              String
  studentId             String?
  university            String
  faculty               String?
  className             String?
  phoneNumber           String?
  email                 String                 @unique
  password              String?
  googleId              String?                @unique
  status                String                 @default("active")
  avatarUrl             String?
  isDeleted             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())
  deletedAt             DateTime?
  createdBy             Int?
  updatedBy             Int?
  deletedBy             Int?

  chatSessions          ChatSession[]
  clubApplications      ClubApplication[]
  formResponses         FormResponse[]
  notifications         Notification[]
  organizationDocuments OrganizationDocument[]
  organizationMembers   OrganizationMember[]
  registrations         Registration[]
  systemLogs            SystemLog[]
  teamMembers           TeamMember[]
  userRoles             UserRole[]

  @@unique([studentId, university])
  @@map("users")
}

// ==========================================
// ORGANIZATIONS
// ==========================================
model Organization {
  organizationId        Int                    @id @default(autoincrement())
  organizationName      String
  organizationType      String
  email                 String?                @unique
  password              String?
  status                String                 @default("active")
  isRecruiting          Boolean                @default(false)
  logoUrl               String?
  coverImageUrl         String?
  leftImageUrl          String?
  rightImageUrl         String?
  middleImageUrl        String?
  description           String?
  tiktokUrl             String?
  facebookUrl           String?
  phoneNumber           String?
  applyDeadline         DateTime?
  responseDeadline      DateTime?
  interviewSchedule     DateTime?
  recruitmentFormId     Int?
  isDeleted             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now())
  deletedAt             DateTime?
  createdBy             Int?
  updatedBy             Int?
  deletedBy             Int?

  activities            Activity[]
  clubApplications      ClubApplication[]
  forms                 Form[]
  organizationDocuments OrganizationDocument[]
  organizationMembers   OrganizationMember[]
  recruitmentForm       Form?                  @relation("OrgRecruitmentForm", fields: [recruitmentFormId], references: [formId])
  systemConfigs         SystemConfig[]

  @@map("organizations")
}

model OrganizationMember {
  userId         Int
  organizationId Int
  role           String?
  joinDate       DateTime?    @db.Date
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  organization   Organization @relation(fields: [organizationId], references: [organizationId])
  user           User         @relation(fields: [userId], references: [userId])

  @@id([userId, organizationId])
  @@map("organization_members")
}

model OrganizationDocument {
  documentId     Int          @id @default(autoincrement())
  documentName   String
  fileUrl        String
  category       String?
  organizationId Int
  userId         Int
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  organization   Organization @relation(fields: [organizationId], references: [organizationId])
  user           User         @relation(fields: [userId], references: [userId])

  @@map("organization_documents")
}

// ==========================================
// ACTIVITIES
// ==========================================
model ActivityCategory {
  categoryId   Int        @id @default(autoincrement())
  categoryName String     @unique
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now())
  deletedAt    DateTime?
  createdBy    Int?
  updatedBy    Int?
  deletedBy    Int?

  activities   Activity[]

  @@map("activity_categories")
}

model Activity {
  activityId           Int               @id @default(autoincrement())
  activityName         String
  description          String?
  coverImage           String?
  location             String?
  activityType         String
  teamMode             String            @default("individual")
  startTime            DateTime?
  endTime              DateTime?
  registrationDeadline DateTime?
  minParticipants      Int?
  maxParticipants      Int?
  activityStatus       String            @default("draft")
  prize                String?
  organizationId       Int
  categoryId           Int
  isDeleted            Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @default(now())
  deletedAt            DateTime?
  createdBy            Int?
  updatedBy            Int?
  deletedBy            Int?

  registrationFormId   Int?

  organization         Organization      @relation(fields: [organizationId], references: [organizationId])
  category             ActivityCategory  @relation(fields: [categoryId], references: [categoryId])
  registrationForm     Form?             @relation("RegistrationForm", fields: [registrationFormId], references: [formId])
  activityCheckins     ActivityCheckin[]
  activityTeamRule     ActivityTeamRule?
  clubApplications     ClubApplication[]
  forms                Form[]            @relation("ActivityForms")
  registrations        Registration[]

  @@map("activities")
}

model ActivityCheckin {
  checkinId         Int       @id @default(autoincrement())
  activityId        Int
  checkInTime       DateTime?
  checkInCloseTime  DateTime?
  checkOutTime      DateTime?
  checkOutCloseTime DateTime?

  activity             Activity              @relation(fields: [activityId], references: [activityId], onDelete: Cascade)
  registrationCheckins RegistrationCheckin[]

  @@map("activity_checkins")
}

model ActivityTeamRule {
  ruleId         Int      @id @default(autoincrement())
  activityId     Int      @unique
  minTeamMembers Int?
  maxTeamMembers Int?

  activity       Activity @relation(fields: [activityId], references: [activityId], onDelete: Cascade)

  @@map("activity_team_rules")
}

// ==========================================
// REGISTRATIONS
// ==========================================
model Registration {
  registrationId   Int       @id @default(autoincrement())
  teamName         String?
  isLookingForTeam Boolean?
  status           String    @default("pending")
  registrationTime DateTime  @default(now())
  registrationType String    @default("individual")
  userId           Int
  activityId       Int
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())
  deletedAt        DateTime?
  createdBy        Int?
  updatedBy        Int?
  deletedBy        Int?

  activity             Activity              @relation(fields: [activityId], references: [activityId])
  user                 User                  @relation(fields: [userId], references: [userId])
  registrationCheckins RegistrationCheckin[]
  review               Review?
  teamMembers          TeamMember[]

  @@unique([userId, activityId])
  @@map("registrations")
}

model RegistrationCheckin {
  checkinId         Int       @id @default(autoincrement())
  registrationId    Int
  activityCheckinId Int?
  checkInTime       DateTime?
  checkOutTime      DateTime?

  registration    Registration     @relation(fields: [registrationId], references: [registrationId], onDelete: Cascade)
  activityCheckin ActivityCheckin? @relation(fields: [activityCheckinId], references: [checkinId])

  @@unique([registrationId, activityCheckinId])
  @@map("registration_checkins")
}

model TeamMember {
  registrationId Int
  userId         Int
  role           String?
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  registration   Registration @relation(fields: [registrationId], references: [registrationId])
  user           User         @relation(fields: [userId], references: [userId])

  @@id([registrationId, userId])
  @@map("team_members")
}

model Review {
  reviewId       Int          @id @default(autoincrement())
  rating         Int
  comment        String?
  reviewTime     DateTime     @default(now())
  registrationId Int          @unique
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  registration   Registration @relation(fields: [registrationId], references: [registrationId])

  @@map("reviews")
}

model ClubApplication {
  applicationId  Int           @id @default(autoincrement())
  submittedAt    DateTime      @default(now())
  interviewTime  DateTime?
  result         String        @default("pending")
  note           String?
  activityId     Int?
  organizationId Int?
  userId         Int
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  activity       Activity?     @relation(fields: [activityId], references: [activityId])
  organization   Organization? @relation(fields: [organizationId], references: [organizationId])
  user           User          @relation(fields: [userId], references: [userId])

  @@unique([activityId, userId])
  @@unique([organizationId, userId])
  @@map("club_applications")
}

// ==========================================
// NOTIFICATIONS
// ==========================================
model Notification {
  notificationId   Int       @id @default(autoincrement())
  title            String
  content          String?
  notificationTime DateTime  @default(now())
  status           String    @default("unread")
  notificationType String?
  userId           Int
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now())
  deletedAt        DateTime?
  createdBy        Int?
  updatedBy        Int?
  deletedBy        Int?

  user             User      @relation(fields: [userId], references: [userId])

  @@map("notifications")
}

// ==========================================
// ROLES
// ==========================================
model Role {
  roleId      Int        @id @default(autoincrement())
  code        String     @unique
  roleName    String     @unique
  description String?
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now())
  deletedAt   DateTime?
  createdBy   Int?
  updatedBy   Int?
  deletedBy   Int?

  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  userId    Int
  roleId    Int
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  role      Role      @relation(fields: [roleId], references: [roleId])
  user      User      @relation(fields: [userId], references: [userId])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ==========================================
// AI CHAT HISTORY
// ==========================================
model ChatSession {
  sessionId Int          @id @default(autoincrement())
  userId    Int
  title     String?
  isDeleted Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [userId])
  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  messageId Int         @id @default(autoincrement())
  sessionId Int
  role      String
  content   String
  createdAt DateTime    @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@map("chat_messages")
}

// ==========================================
// SYSTEM
// ==========================================
model SystemLog {
  logId         Int       @id @default(autoincrement())
  action        String?
  executionTime DateTime  @default(now())
  oldData       String?
  newData       String?
  userId        Int
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  deletedAt     DateTime?
  createdBy     Int?
  updatedBy     Int?
  deletedBy     Int?

  user          User      @relation(fields: [userId], references: [userId])

  @@map("system_logs")
}

// ==========================================
// SYSTEM CONFIG
// ==========================================
model SystemConfig {
  configId       Int           @id @default(autoincrement())
  key            String
  value          Json
  dataType       String
  category       String
  label          String
  description    String?
  organizationId Int?
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now())
  deletedAt      DateTime?
  createdBy      Int?
  updatedBy      Int?
  deletedBy      Int?

  organization   Organization? @relation(fields: [organizationId], references: [organizationId])

  @@unique([key, organizationId])
  @@index([category])
  @@index([organizationId])
  @@map("system_configs")
}

// ==========================================
// FORMS
// ==========================================
model Form {
  formId              Int            @id @default(autoincrement())
  title               String
  description         String?
  headerImageUrl      String?
  confirmationMessage String?
  status              String         @default("draft")
  collectEmail        Boolean        @default(false)
  limitOneResponse    Boolean        @default(true)
  allowEditResponse   Boolean        @default(false)
  showProgressBar     Boolean        @default(false)
  shuffleQuestions    Boolean        @default(false)
  requireSignIn       Boolean        @default(true)
  responseLimit       Int?
  openAt              DateTime?
  closeAt             DateTime?
  activityId          Int?
  organizationId      Int?
  isDeleted           Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now())
  deletedAt           DateTime?
  createdBy           Int?
  updatedBy           Int?
  deletedBy           Int?

  activity              Activity?      @relation("ActivityForms", fields: [activityId], references: [activityId])
  organization          Organization?  @relation(fields: [organizationId], references: [organizationId])
  activityRegistrations Activity[]     @relation("RegistrationForm")
  orgRecruitments       Organization[] @relation("OrgRecruitmentForm")
  sections              FormSection[]
  responses             FormResponse[]

  @@index([organizationId])
  @@index([activityId])
  @@map("forms")
}

model FormSection {
  sectionId      Int        @id @default(autoincrement())
  title          String
  description    String?
  order          Int        @default(0)
  navigationType String     @default("next")
  formId         Int
  isDeleted      Boolean    @default(false)

  form           Form       @relation(fields: [formId], references: [formId], onDelete: Cascade)
  questions      Question[]

  @@map("form_sections")
}

model Question {
  questionId       Int              @id @default(autoincrement())
  title            String
  description      String?
  type             String
  order            Int              @default(0)
  required         Boolean          @default(false)
  scaleMin         Int?
  scaleMax         Int?
  scaleMinLabel    String?
  scaleMaxLabel    String?
  allowedFileTypes String[]         @default([])
  maxFileSize      Int?
  maxFiles         Int?
  imageUrl         String?
  videoUrl         String?
  validationRules  Json?
  displayCondition Json?
  sectionId        Int
  isDeleted        Boolean          @default(false)

  section          FormSection      @relation(fields: [sectionId], references: [sectionId], onDelete: Cascade)
  options          QuestionOption[]
  gridRows         GridRow[]
  answers          Answer[]

  @@map("questions")
}

model QuestionOption {
  optionId      Int            @id @default(autoincrement())
  label         String
  order         Int            @default(0)
  isOther       Boolean        @default(false)
  imageUrl      String?
  goToSectionId Int?
  questionId    Int
  isDeleted     Boolean        @default(false)

  question      Question       @relation(fields: [questionId], references: [questionId], onDelete: Cascade)
  answerOptions AnswerOption[]

  @@map("question_options")
}

model GridRow {
  rowId         Int            @id @default(autoincrement())
  label         String
  order         Int            @default(0)
  questionId    Int
  isDeleted     Boolean        @default(false)

  question      Question       @relation(fields: [questionId], references: [questionId], onDelete: Cascade)
  answerOptions AnswerOption[]

  @@map("grid_rows")
}

model FormResponse {
  responseId      Int      @id @default(autoincrement())
  status          String   @default("submitted")
  respondentEmail String?
  submittedAt     DateTime @default(now())
  formId          Int
  userId          Int?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  form            Form     @relation(fields: [formId], references: [formId])
  user            User?    @relation(fields: [userId], references: [userId])
  answers         Answer[]

  @@map("form_responses")
}

model Answer {
  answerId      Int            @id @default(autoincrement())
  textValue     String?
  fileUrl       String?
  questionId    Int
  responseId    Int
  isDeleted     Boolean        @default(false)

  question      Question       @relation(fields: [questionId], references: [questionId])
  response      FormResponse   @relation(fields: [responseId], references: [responseId], onDelete: Cascade)
  answerOptions AnswerOption[]

  @@map("answers")
}

model AnswerOption {
  answerOptionId Int             @id @default(autoincrement())
  otherText      String?
  answerId       Int
  optionId       Int?
  rowId          Int?
  isDeleted      Boolean         @default(false)

  answer         Answer          @relation(fields: [answerId], references: [answerId], onDelete: Cascade)
  option         QuestionOption? @relation(fields: [optionId], references: [optionId])
  row            GridRow?        @relation(fields: [rowId], references: [rowId])

  @@map("answer_options")
}
