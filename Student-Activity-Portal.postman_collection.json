{
  "info": {
    "name": "Student Activity Portal",
    "description": "API collection for Student Activity Portal backend. Base URL: http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Nguyen Van A\",\n  \"email\": \"nguyenvana@example.com\",\n  \"password\": \"password123\",\n  \"university\": \"Dai hoc Bach Khoa\",\n  \"studentId\": \"SV001\",\n  \"phoneNumber\": \"0912345678\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  }",
                  "  if (res.data.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@test.com\",\n  \"password\": \"Student@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login. Token is automatically saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  }",
                  "  if (res.data.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"Admin@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as admin. Token is automatically saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh-token"]
            }
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nguyenvana@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"newPassword\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            }
          },
          "response": []
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"newpassword456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "change-password"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Send Notification (admin/organization_leader)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.notificationId) {",
                  "  pm.collectionVariables.set('notificationId', res.data.notificationId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Notification\",\n  \"content\": \"Notification content here\",\n  \"userId\": 1,\n  \"notificationType\": \"system\",\n  \"channels\": [\"IN_APP\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/notifications/send",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "send"]
            },
            "description": "Send notification to a single user. channels: IN_APP, EMAIL, SMS. Requires role admin or organization_leader."
          },
          "response": []
        },
        {
          "name": "Send Bulk Notification (admin/organization_leader)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Broadcast Notification\",\n  \"content\": \"Content for all users\",\n  \"notificationType\": \"system\",\n  \"channels\": [\"IN_APP\", \"EMAIL\"],\n  \"sendToAll\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/notifications/send-bulk",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "send-bulk"]
            },
            "description": "Send bulk notification. Target: sendToAll=true (all users), organizationId (club members), userIds (specific list). Use scheduledAt for scheduled delivery."
          },
          "response": []
        },
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notifications?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "notificationType", "value": "system", "disabled": true },
                { "key": "status", "value": "unread", "disabled": true }
              ]
            },
            "description": "Get paginated notifications for current user. Filter by notificationType (system/activity/registration) and status (unread/read)."
          },
          "response": []
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "stats"]
            }
          },
          "response": []
        },
        {
          "name": "Get Notification By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/{{notificationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "{{notificationId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Mark As Read",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "{{notificationId}}", "read"]
            }
          },
          "response": []
        },
        {
          "name": "Mark All As Read",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "read-all"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/{{notificationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "{{notificationId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Smart Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"hoat dong the thao\",\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "search"]
            },
            "description": "Smart activity search using AI (Gemini)."
          },
          "response": []
        },
        {
          "name": "Recommendations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limit\": 5\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "recommend"]
            },
            "description": "Activity recommendations based on history and preferences."
          },
          "response": []
        },
        {
          "name": "Ask Q&A",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Co hoat dong nao sap dien ra khong?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/ask",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "ask"]
            },
            "description": "Q&A about activities and clubs using AI."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Overview Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/stats/overview",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "stats", "overview"]
            },
            "description": "Overview stats: users, activities, clubs, registrations. Requires admin role."
          },
          "response": []
        },
        {
          "name": "Activity Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/stats/activities",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "stats", "activities"]
            },
            "description": "Activity stats by status and type. Requires admin role."
          },
          "response": []
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.userId) {",
                  "  pm.collectionVariables.set('createdUserId', res.data.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"Nguyen Van B\",\n  \"email\": \"nguyenvanb@example.com\",\n  \"password\": \"Pass@1234\",\n  \"university\": \"Dai hoc Bach Khoa\",\n  \"studentId\": \"SV002\",\n  \"phoneNumber\": \"0987654321\",\n  \"role\": \"student\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"]
            },
            "description": "Create a single user. role: student | organization_leader | organization_member | admin. Role is auto-assigned to user_roles table. Requires admin role."
          },
          "response": []
        },
        {
          "name": "Import Users from CSV",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"csv\": \"userName,email,password,university,studentId,phoneNumber,role\\nNguyen Van C,nguyenvanc@example.com,Pass@1234,Dai hoc Bach Khoa,SV003,0911111111,student\\nTran Thi D,tranthid@example.com,Pass@1234,Dai hoc HUST,SV004,,organization_member\\nLe Van E,levane@example.com,Pass@1234,Dai hoc FPT,,,student\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/import",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "import"]
            },
            "description": "Import multiple users from CSV data.\n\nRequired CSV columns: userName, email, password, university\nOptional columns: studentId, phoneNumber, role (default: student)\n\nTwo ways to send:\n1. JSON body: { \"csv\": \"header\\nrow1\\nrow2\" }\n2. Raw CSV: Content-Type: text/csv — send CSV file content directly\n\nResponse: { total, created, failed, createdUsers[], errors[] }\nErrors are collected per row — one bad row does NOT stop the rest."
          },
          "response": []
        },
        {
          "name": "Import Users from CSV (raw text/csv)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "text/csv" }
            ],
            "body": {
              "mode": "raw",
              "raw": "userName,email,password,university,studentId,role\nNguyen Van F,nguyenvanf@example.com,Pass@1234,Dai hoc Bach Khoa,SV005,student\nTran Thi G,tranthig@example.com,Pass@1234,Dai hoc HUST,,organization_member"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/import",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users", "import"]
            },
            "description": "Same as Import Users from CSV but sends raw CSV with Content-Type: text/csv. Useful when uploading a .csv file directly."
          },
          "response": []
        }
      ]
    }
  ]
}
